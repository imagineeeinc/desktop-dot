{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "cssPriority": "user",
  "control-center-margin-top": 11,
  "control-center-margin-bottom": 11,
  "control-center-margin-right": 15,
  "control-center-margin-left": 0,
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 5,
  "timeout-low": 5,
  "timeout-critical": 10,
  "fit-to-screen": true,
  "relative-timestamps": true,
  "control-center-width": 500,
  "control-center-height": 600,
  "notification-window-width": 400,
  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "No Notifications",
  "script-fail-notify": true,
  "widgets": [
    "buttons-grid",
    "backlight",
    "volume",
    "mpris",
    "title",
    "notifications"
  ],
  "widget-config": {
    "mpris": {
      "blacklist": ["vivaldi.instance2"],
      "autohide": false,
      "show-album-art": "always",
      "loop-carousel": false
    },
    "notifications": {
      "vexpand": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰎟"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "buttons-grid": {
      "buttons-per-row": 7,
      "actions": [
        {
          "label": "󰤨",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
          "update-command": "sh -c '[[ $(nmcli radio wifi) == \"enabled\" ]] && echo true || echo false'"
        },
        {
          "label": "󰂯",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && bluetoothctl power on || bluetoothctl power off'",
          "update-command": "sh -c 'bluetoothctl show | grep -q \\\"Powered: yes\\\" && echo true || echo false'"
        },
        {
          "label": "󰸷",
          "type": "normal",
          "command": "swaync-client -t && steam steam://open/bigpicture"
        },
        {
          "label": "",
          "type": "normal",
          "command": "swaync-client -t && gnome-calculator"
        },
        {
          "label": "",
          "type": "toggle",
          "active": false,
          "command": ""
        }
      ]
    },
    "backlight": {
      "label": "󰃠",
      "device": "amdgpu_bl1"
    },
    "volume": {
      "label": "",
      "show-per-app": true,
      "show-per-app-icon": true,
      "show-per-app-label": false,
      "expand-per-app": false,
      "animation-type": "slide_up",
      "animation-duration": 200,
      "expand-button-label": "",
      "collapse-button-label": ""
    }
  }
}
